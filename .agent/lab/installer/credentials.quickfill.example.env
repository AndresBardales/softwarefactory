# Kaanbal Installer quick-fill template
# Usage:
# 1) Copy this file and fill your real values.
# 2) In installer welcome screen, click the upload area and load the file.
# 3) Fields are prefilled; validate each section and click Next.
#
# Notes:
# - Keep this file local only. Never commit secrets to git.
# - The installer also stores a temporary browser local cache for fast retries.

# Core
KB_MODE=hybrid
KB_DOMAIN=example.com

# Admin / Control plane
KB_ADMIN_USER=admin
KB_ADMIN_PASSWORD=change-me
KB_ARGOCD_PASSWORD=change-me
KB_VAULT_TOKEN=change-me

# Git
KB_GIT_PROVIDER=github
KB_GIT_USER=your-git-user
KB_GIT_EMAIL=you@example.com
KB_GIT_TOKEN=ghp_xxx
KB_GIT_WORKSPACE=your-git-user

# Docker
KB_DOCKER_USER=your-docker-user
KB_DOCKER_TOKEN=dckr_pat_xxx

# Cloudflare
KB_CLOUDFLARE_TOKEN=cf_token_xxx
KB_CLOUDFLARE_ACCOUNT_ID=your_account_id

# Tailscale
KB_TAILSCALE_ENABLED=true
KB_TAILSCALE_CLIENT_ID=ts_oauth_client_id
KB_TAILSCALE_CLIENT_SECRET=tskey-client-xxx
KB_TAILSCALE_DNS_SUFFIX=tailxxxx.ts.net
KB_TAILSCALE_ACL_TOKEN=tskey-api-xxx

# Optional AWS (not required in all flows)
KB_AWS_ACCESS_KEY=
KB_AWS_SECRET_KEY=
KB_AWS_REGION=us-east-1
