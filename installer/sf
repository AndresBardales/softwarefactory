#!/usr/bin/env bash
# ==============================================================================
# sf — Software Factory CLI
# ==============================================================================
# Usage: sf <command> [options]
#
# Commands:
#   install     Install Software Factory (runs the installer wizard)
#   status      Show cluster health and app status
#   apps        List deployed applications
#   logs        View logs for an app or component
#   upgrade     Upgrade Software Factory to latest version
#   config      Show or edit configuration
#   add-worker  Add a cloud worker node (hybrid/cloud mode)
#   uninstall   Remove Software Factory (keeps data by default)
#   help        Show this help message
# ==============================================================================

set -euo pipefail

SF_HOME="${SF_HOME:-$HOME/.software-factory}"
SF_CONFIG="$SF_HOME/config.env"

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'

# Load config if available
[ -f "$SF_CONFIG" ] && source "$SF_CONFIG"

# ==============================================================================

cmd_status() {
  echo -e "${BOLD}${CYAN}Software Factory Status${NC}"
  echo ""

  # Mode
  echo -e "  ${BOLD}Mode:${NC}    ${SF_MODE:-unknown}"
  echo -e "  ${BOLD}Domain:${NC}  ${SF_DOMAIN:-localhost}"
  echo ""

  # Nodes
  echo -e "  ${BOLD}Nodes:${NC}"
  kubectl get nodes -o custom-columns="NAME:.metadata.name,STATUS:.status.conditions[-1].type,VERSION:.status.nodeInfo.kubeletVersion,CPU:.status.capacity.cpu,MEMORY:.status.capacity.memory" 2>/dev/null \
    | sed 's/^/    /'
  echo ""

  # Core Services
  echo -e "  ${BOLD}Core Services:${NC}"
  local services=("prod:datastore:MongoDB" "prod:nexus-api:API" "prod:nexus-console:Console" "argocd:argocd-server:ArgoCD" "vault:vault:Vault")
  for svc in "${services[@]}"; do
    IFS=: read -r ns app label <<< "$svc"
    local status
    status=$(kubectl -n "$ns" get pod -l "app=$app" -o jsonpath='{.items[0].status.phase}' 2>/dev/null || \
             kubectl -n "$ns" get pod -l "app.kubernetes.io/name=$app" -o jsonpath='{.items[0].status.phase}' 2>/dev/null || \
             echo "NotFound")
    local restarts
    restarts=$(kubectl -n "$ns" get pod -l "app=$app" -o jsonpath='{.items[0].status.containerStatuses[0].restartCount}' 2>/dev/null || echo "?")

    if [ "$status" = "Running" ]; then
      echo -e "    ${GREEN}●${NC} ${label}: Running (restarts: ${restarts})"
    else
      echo -e "    ${RED}●${NC} ${label}: ${status}"
    fi
  done
  echo ""

  # Resource usage
  echo -e "  ${BOLD}Resource Usage:${NC}"
  kubectl top nodes 2>/dev/null | sed 's/^/    /' || echo "    (metrics-server not available)"
  echo ""

  # App count
  local app_count
  app_count=$(kubectl -n prod get pods -l "app notin (datastore,nexus-api,nexus-console)" --no-headers 2>/dev/null | wc -l)
  echo -e "  ${BOLD}User Apps:${NC} ${app_count} pods in prod"
}

cmd_apps() {
  echo -e "${BOLD}${CYAN}Deployed Applications${NC}"
  echo ""

  # Get from nexus-api if available
  local api_ip
  api_ip=$(kubectl -n prod get pod -l app=nexus-api -o jsonpath='{.items[0].status.podIP}' 2>/dev/null)

  if [ -n "$api_ip" ]; then
    local token
    token=$(curl -sf --max-time 5 -X POST "http://${api_ip}:8000/api/v1/auth/token" \
      -H "Content-Type: application/x-www-form-urlencoded" \
      -d "username=${SF_ADMIN_USER:-admin}&password=${SF_ADMIN_PASSWORD:-}" \
      2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('access_token',''))" 2>/dev/null || echo "")

    if [ -n "$token" ]; then
      curl -sf --max-time 10 "http://${api_ip}:8000/api/v1/apps" \
        -H "Authorization: Bearer ${token}" 2>/dev/null \
        | python3 -c "
import sys, json
apps = json.load(sys.stdin)
if not apps:
    print('  No apps deployed yet. Use the UI to create your first app!')
else:
    print(f'  {len(apps)} app(s) deployed:')
    print()
    for a in apps:
        name = a.get('name', '?')
        status = a.get('status', '?')
        envs = ', '.join(a.get('environments', []))
        template = a.get('template', '?')
        icon = '●' if status == 'running' else '○'
        print(f'  {icon} {name:<25} {status:<12} [{template}] envs: {envs}')
" 2>/dev/null
    else
      echo "  Could not authenticate. Run 'sf config' to check credentials."
    fi
  else
    echo "  nexus-api not available. Listing pods directly:"
    echo ""
    kubectl get pods -n prod --no-headers 2>/dev/null | grep -v "datastore\|nexus-" | awk '{printf "  %-35s %s\n", $1, $3}'
  fi
}

cmd_logs() {
  local app="${1:-}"
  if [ -z "$app" ]; then
    echo "Usage: sf logs <app-name> [--env prod|dev|staging] [--follow]"
    return 1
  fi

  local namespace="prod"
  local follow=""

  shift
  while [ $# -gt 0 ]; do
    case "$1" in
      --env) namespace="$2"; shift 2 ;;
      --follow|-f) follow="-f"; shift ;;
      *) shift ;;
    esac
  done

  echo -e "${BOLD}Logs for ${app} (namespace: ${namespace})${NC}"
  kubectl logs -n "$namespace" -l "app=$app" --tail=100 $follow 2>/dev/null || \
    echo "No pods found for app '$app' in namespace '$namespace'"
}

cmd_config() {
  echo -e "${BOLD}${CYAN}Software Factory Configuration${NC}"
  echo -e "  ${BOLD}Config file:${NC} $SF_CONFIG"
  echo ""

  if [ -f "$SF_CONFIG" ]; then
    # Show config without secrets
    while IFS='=' read -r key value; do
      [[ "$key" =~ ^#.*$ ]] && continue
      [[ -z "$key" ]] && continue
      # Mask sensitive values
      if [[ "$key" =~ TOKEN|PASSWORD|SECRET|KEY ]]; then
        echo -e "  ${key}=***"
      else
        echo -e "  ${key}=${value}"
      fi
    done < "$SF_CONFIG"
  else
    echo "  No configuration found. Run 'sf install' first."
  fi
}

cmd_upgrade() {
  # -----------------------------------------------------------------------
  # sf upgrade — Check versions manifest, download, validate, apply
  # -----------------------------------------------------------------------
  local VERSIONS_URL="https://raw.githubusercontent.com/AndresBardales/softwarefactory/main/versions.json"
  local CHANNEL="${SF_UPDATE_CHANNEL:-stable}"
  local CURRENT_VERSION="${SF_VERSION:-0.0.0}"

  echo -e "${BOLD}${CYAN}Software Factory Upgrade${NC}"
  echo ""
  echo -e "  ${BOLD}Current version:${NC} v${CURRENT_VERSION}  (channel: ${CHANNEL})"
  echo ""

  # --- 1. Parse flags -------------------------------------------------------
  local CHECK_ONLY=false
  local FORCE=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --check)        CHECK_ONLY=true; shift ;;
      --force)        FORCE=true; shift ;;
      --channel=*)    CHANNEL="${1#*=}"; shift ;;
      *) shift ;;
    esac
  done

  # --- 2. Fetch the versions manifest ---------------------------------------
  echo -e "  ${BLUE}[→]${NC} Fetching versions manifest..."
  local manifest
  manifest=$(curl -sf --max-time 15 "$VERSIONS_URL" 2>/dev/null) || {
    echo -e "  ${RED}[✗]${NC} Could not reach the versions manifest."
    echo -e "       Check internet: curl -s $VERSIONS_URL"
    return 1
  }

  local latest_version
  latest_version=$(echo "$manifest" | python3 -c \
    "import sys,json; d=json.load(sys.stdin); print(d['channels'].get('$CHANNEL',''))" 2>/dev/null) || {
    echo -e "  ${RED}[✗]${NC} Could not parse versions manifest."
    return 1
  }

  if [ -z "$latest_version" ]; then
    echo -e "  ${YELLOW}[!]${NC} No release found for channel '${CHANNEL}'."
    return 0
  fi

  echo -e "  ${BOLD}Latest ($CHANNEL):${NC}  v${latest_version}"
  echo ""

  # --- 3. Compare versions --------------------------------------------------
  if [ "$CURRENT_VERSION" = "$latest_version" ] && [ "$FORCE" = "false" ]; then
    echo -e "  ${GREEN}[✓]${NC} Already up to date!"
    return 0
  fi

  if [ "$CHECK_ONLY" = "true" ]; then
    echo -e "  ${YELLOW}[!]${NC} New version available: v${latest_version}"
    echo -e "       Run 'sf upgrade' to apply."
    return 0
  fi

  echo -e "  ${YELLOW}[!]${NC} Upgrading: v${CURRENT_VERSION} → v${latest_version}"
  echo ""

  # --- 4. Get installer URL from manifest -----------------------------------
  local installer_url
  installer_url=$(echo "$manifest" | python3 -c \
    "import sys,json; d=json.load(sys.stdin); print(d['latest']['installer_url'])" 2>/dev/null) || {
    echo -e "  ${RED}[✗]${NC} Could not parse installer URL from manifest."
    return 1
  }

  local checksum_url
  checksum_url=$(echo "$manifest" | python3 -c \
    "import sys,json; d=json.load(sys.stdin); print(d['latest'].get('checksum_url',''))" 2>/dev/null || echo "")

  # --- 5. Download new installer --------------------------------------------
  local tmpdir
  tmpdir=$(mktemp -d /tmp/sf-upgrade-XXXXXX)
  trap "rm -rf '$tmpdir'" EXIT

  echo -e "  ${BLUE}[→]${NC} Downloading installer v${latest_version}..."
  if ! curl -sL --max-time 120 "$installer_url" -o "$tmpdir/installer.tar.gz"; then
    echo -e "  ${RED}[✗]${NC} Download failed. Check your internet connection."
    return 1
  fi

  # --- 6. Validate checksum (if available) ----------------------------------
  if [ -n "$checksum_url" ]; then
    echo -e "  ${BLUE}[→]${NC} Validating checksum..."
    if curl -sL --max-time 30 "$checksum_url" -o "$tmpdir/checksums.sha256" 2>/dev/null; then
      pushd "$tmpdir" > /dev/null
      if sha256sum --check --status checksums.sha256 2>/dev/null; then
        echo -e "  ${GREEN}[✓]${NC} Checksum valid."
      else
        echo -e "  ${RED}[✗]${NC} Checksum mismatch! Aborting for safety."
        popd > /dev/null
        return 1
      fi
      popd > /dev/null
    else
      echo -e "  ${YELLOW}[!]${NC} Checksum file not available — skipping validation."
    fi
  fi

  # --- 7. Backup current installer ------------------------------------------
  local sf_root
  sf_root="$(cd "$(dirname "$0")/.." && pwd)"

  local backup_dir
  backup_dir="${sf_root%/softwarefactory}/sf-backup-v${CURRENT_VERSION}-$(date +%Y%m%d%H%M%S)"

  echo -e "  ${BLUE}[→]${NC} Backing up current installer to:"
  echo -e "       $backup_dir"
  cp -r "$sf_root" "$backup_dir" 2>/dev/null || {
    echo -e "  ${YELLOW}[!]${NC} Could not create backup — upgrade continues but rollback will be manual."
  }

  # --- 8. Extract and apply -------------------------------------------------
  echo -e "  ${BLUE}[→]${NC} Extracting new version..."
  tar -xzf "$tmpdir/installer.tar.gz" -C "$tmpdir" 2>/dev/null || {
    echo -e "  ${RED}[✗]${NC} Failed to extract archive."
    return 1
  }

  # Find extracted dir (GitHub archives like softwarefactory-0.2.0/)
  local extracted_dir
  extracted_dir=$(find "$tmpdir" -maxdepth 1 -mindepth 1 -type d | head -1)

  if [ -z "$extracted_dir" ]; then
    echo -e "  ${RED}[✗]${NC} Archive had unexpected structure."
    return 1
  fi

  echo -e "  ${BLUE}[→]${NC} Applying update..."
  rsync -a --exclude='.git' --exclude='installer/templates/' \
    "${extracted_dir}/" "${sf_root}/" 2>/dev/null || {
    echo -e "  ${RED}[✗]${NC} Failed to apply update."
    echo -e "       Rollback: cp -r ${backup_dir} ${sf_root}"
    return 1
  }

  # --- 9. Update stored version in config -----------------------------------
  if [ -f "$SF_CONFIG" ]; then
    if grep -q "^SF_VERSION=" "$SF_CONFIG" 2>/dev/null; then
      sed -i "s/^SF_VERSION=.*/SF_VERSION=${latest_version}/" "$SF_CONFIG"
    else
      echo "SF_VERSION=${latest_version}" >> "$SF_CONFIG"
    fi
  fi

  # --- 10. Restart core platform services -----------------------------------
  echo -e "  ${BLUE}[→]${NC} Restarting platform services..."
  local docker_user="${SF_DOCKER_USER:-${SF_DOCKER_USERNAME:-}}"
  if [ -n "$docker_user" ]; then
    kubectl -n prod rollout restart deployment/nexus-api deployment/nexus-console 2>/dev/null || true
  fi

  # --- 11. Done -------------------------------------------------------------
  echo ""
  echo -e "  ${GREEN}[✓]${NC} Upgraded successfully to v${latest_version}"
  echo ""
  echo -e "  ${BOLD}Rollback:${NC}"
  echo -e "    cp -r ${backup_dir} ${sf_root}"
  echo -e "    sf status"
  echo ""
  echo -e "  ${BOLD}Changelog:${NC}"
  local changelog
  changelog=$(echo "$manifest" | python3 -c \
    "import sys,json; d=json.load(sys.stdin); print(d['latest'].get('changelog',''))" 2>/dev/null || echo "")
  [ -n "$changelog" ] && echo -e "    $changelog"
}

cmd_add_worker() {
  echo -e "${BOLD}${CYAN}Add Cloud Worker${NC}"
  echo ""

  if [ "${SF_MODE:-}" = "local" ]; then
    echo "  Worker nodes are only available in cloud or hybrid mode."
    echo "  Current mode: local"
    echo ""
    echo "  To switch to hybrid mode, run: sf config --set SF_MODE=hybrid"
    return 1
  fi

  echo "  This will add a new worker node to your cluster."
  echo "  Provider: AWS (region: ${SF_AWS_REGION:-us-east-1})"
  echo ""
  echo "  [!] Not yet implemented. Planned for v1.1."
  echo "  For now, modify worker_desired_count in terraform.tfvars and run terraform apply."
}

cmd_help() {
  cat <<HELP
${BOLD}Software Factory CLI v${SF_VERSION:-0.1.0}${NC}

${BOLD}Usage:${NC} sf <command> [options]

${BOLD}Commands:${NC}
  install                 Install Software Factory (interactive wizard)
  status                  Show cluster health, nodes, and services
  apps                    List all deployed applications
  logs <app>              View logs for an app (--env, --follow)
  config                  Show current configuration
  upgrade                 Upgrade to latest release (channel: stable)
  upgrade --check         Check for new version without installing
  upgrade --channel=rc    Use a specific channel (stable, rc)
  upgrade --force         Re-apply current version (useful after rollback)
  add-worker              Add a cloud worker node (cloud/hybrid)
  uninstall               Remove Software Factory
  help                    Show this help

${BOLD}Examples:${NC}
  sf status                       Check everything is running
  sf apps                         See your deployed apps
  sf logs my-api --follow         Stream logs from my-api
  sf upgrade                      Update to latest stable version
  sf upgrade --check              Check for updates without applying
  sf upgrade --channel=rc         Try a release candidate

${BOLD}Environment:${NC}
  SF_HOME             Config directory (default: ~/.software-factory)
  SF_UPDATE_CHANNEL   Default upgrade channel (default: stable)

HELP
}

# ==============================================================================
# MAIN
# ==============================================================================

command="${1:-help}"
shift 2>/dev/null || true

case "$command" in
  install)    exec bash "$(dirname "$0")/install.sh" ;;
  status)     cmd_status ;;
  apps)       cmd_apps ;;
  logs)       cmd_logs "$@" ;;
  config)     cmd_config ;;
  upgrade)    cmd_upgrade "$@" ;;
  add-worker) cmd_add_worker ;;
  --version|-v) echo "Software Factory v${SF_VERSION:-0.1.0}" ;;
  help|--help|-h) cmd_help ;;
  *)
    echo -e "${RED}Unknown command: $command${NC}"
    echo "Run 'sf help' for usage."
    exit 1
    ;;
esac
