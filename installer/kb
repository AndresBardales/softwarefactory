#!/usr/bin/env bash
# ==============================================================================
# kb â€” Kaanbal Engine CLI
# ==============================================================================
# Usage: kb <command> [options]
#
# Commands:
#   install     Install Kaanbal Engine (runs the installer wizard)
#   status      Show cluster health and app status
#   apps        List deployed applications
#   logs        View logs for an app or component
#   upgrade     Upgrade Kaanbal Engine to latest version
#   config      Show or edit configuration
#   add-worker  Add a cloud worker node (hybrid/cloud mode)
#   uninstall   Remove Kaanbal Engine (keeps data by default)
#   help        Show this help message
# ==============================================================================

set -euo pipefail

KB_HOME="${KB_HOME:-$HOME/.kaanbal}"
KB_CONFIG="$KB_HOME/config.env"

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'

# Load config if available
[ -f "$KB_CONFIG" ] && source "$KB_CONFIG"

# ==============================================================================

cmd_status() {
  echo -e "${BOLD}${CYAN}Kaanbal Engine Status${NC}"
  echo ""

  # Mode
  echo -e "  ${BOLD}Mode:${NC}    ${KB_MODE:-unknown}"
  echo -e "  ${BOLD}Domain:${NC}  ${KB_DOMAIN:-localhost}"
  echo ""

  # Nodes
  echo -e "  ${BOLD}Nodes:${NC}"
  kubectl get nodes -o custom-columns="NAME:.metadata.name,STATUS:.status.conditions[-1].type,VERSION:.status.nodeInfo.kubeletVersion,CPU:.status.capacity.cpu,MEMORY:.status.capacity.memory" 2>/dev/null \
    | sed 's/^/    /'
  echo ""

  # Core Services
  echo -e "  ${BOLD}Core Services:${NC}"
  local services=("prod:datastore:MongoDB" "prod:kaanbal-api:API" "prod:kaanbal-console:Console" "argocd:argocd-server:ArgoCD" "vault:vault:Vault")
  for svc in "${services[@]}"; do
    IFS=: read -r ns app label <<< "$svc"
    local status
    status=$(kubectl -n "$ns" get pod -l "app=$app" -o jsonpath='{.items[0].status.phase}' 2>/dev/null || \
             kubectl -n "$ns" get pod -l "app.kubernetes.io/name=$app" -o jsonpath='{.items[0].status.phase}' 2>/dev/null || \
             echo "NotFound")
    local restarts
    restarts=$(kubectl -n "$ns" get pod -l "app=$app" -o jsonpath='{.items[0].status.containerStatuses[0].restartCount}' 2>/dev/null || echo "?")

    if [ "$status" = "Running" ]; then
      echo -e "    ${GREEN}â—Ź${NC} ${label}: Running (restarts: ${restarts})"
    else
      echo -e "    ${RED}â—Ź${NC} ${label}: ${status}"
    fi
  done
  echo ""

  # Resource usage
  echo -e "  ${BOLD}Resource Usage:${NC}"
  kubectl top nodes 2>/dev/null | sed 's/^/    /' || echo "    (metrics-server not available)"
  echo ""

  # App count
  local app_count
  app_count=$(kubectl -n prod get pods -l "app notin (datastore,kaanbal-api,kaanbal-console)" --no-headers 2>/dev/null | wc -l)
  echo -e "  ${BOLD}User Apps:${NC} ${app_count} pods in prod"
}

cmd_apps() {
  echo -e "${BOLD}${CYAN}Deployed Applications${NC}"
  echo ""

  # Get from kaanbal-api if available
  local api_ip
  api_ip=$(kubectl -n prod get pod -l app=kaanbal-api -o jsonpath='{.items[0].status.podIP}' 2>/dev/null)

  if [ -n "$api_ip" ]; then
    local token
    token=$(curl -sf --max-time 5 -X POST "http://${api_ip}:8000/api/v1/auth/token" \
      -H "Content-Type: application/x-www-form-urlencoded" \
      -d "username=${KB_ADMIN_USER:-admin}&password=${KB_ADMIN_PASSWORD:-}" \
      2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('access_token',''))" 2>/dev/null || echo "")

    if [ -n "$token" ]; then
      curl -sf --max-time 10 "http://${api_ip}:8000/api/v1/apps" \
        -H "Authorization: Bearer ${token}" 2>/dev/null \
        | python3 -c "
import sys, json
apps = json.load(sys.stdin)
if not apps:
    print('  No apps deployed yet. Use the UI to create your first app!')
else:
    print(f'  {len(apps)} app(s) deployed:')
    print()
    for a in apps:
        name = a.get('name', '?')
        status = a.get('status', '?')
        envs = ', '.join(a.get('environments', []))
        template = a.get('template', '?')
        icon = 'â—Ź' if status == 'running' else 'â—‹'
        print(f'  {icon} {name:<25} {status:<12} [{template}] envs: {envs}')
" 2>/dev/null
    else
      echo "  Could not authenticate. Run 'kb config' to check credentials."
    fi
  else
    echo "  kaanbal-api not available. Listing pods directly:"
    echo ""
    kubectl get pods -n prod --no-headers 2>/dev/null | grep -v "datastore\|kaanbal-" | awk '{printf "  %-35s %s\n", $1, $3}'
  fi
}

cmd_logs() {
  local app="${1:-}"
  if [ -z "$app" ]; then
    echo "Usage: kb logs <app-name> [--env prod|dev|staging] [--follow]"
    return 1
  fi

  local namespace="prod"
  local follow=""

  shift
  while [ $# -gt 0 ]; do
    case "$1" in
      --env) namespace="$2"; shift 2 ;;
      --follow|-f) follow="-f"; shift ;;
      *) shift ;;
    esac
  done

  echo -e "${BOLD}Logs for ${app} (namespace: ${namespace})${NC}"
  kubectl logs -n "$namespace" -l "app=$app" --tail=100 $follow 2>/dev/null || \
    echo "No pods found for app '$app' in namespace '$namespace'"
}

cmd_config() {
  echo -e "${BOLD}${CYAN}Kaanbal Engine Configuration${NC}"
  echo -e "  ${BOLD}Config file:${NC} $KB_CONFIG"
  echo ""

  if [ -f "$KB_CONFIG" ]; then
    # Show config without secrets
    while IFS='=' read -r key value; do
      [[ "$key" =~ ^#.*$ ]] && continue
      [[ -z "$key" ]] && continue
      # Mask sensitive values
      if [[ "$key" =~ TOKEN|PASSWORD|SECRET|KEY ]]; then
        echo -e "  ${key}=***"
      else
        echo -e "  ${key}=${value}"
      fi
    done < "$KB_CONFIG"
  else
    echo "  No configuration found. Run 'kb install' first."
  fi
}

cmd_upgrade() {
  echo -e "${BOLD}${CYAN}Kaanbal Engine Upgrade${NC}"
  echo ""

  local current_version="${KB_VERSION:-0.0.0}"
  local kb_dir="${KB_INSTALL_DIR:-$HOME/softwarefactory}"
  local repo_url="${KB_REPO_URL:-https://github.com/AndresBardales/softwarefactory}"
  local manifest_url="${repo_url}/raw/main/versions.json"
  local channel="${1:-stable}"

  # Step 1: Check for new version
  echo -e "  ${BLUE}[â†’]${NC} Checking for updates (channel: ${channel})..."
  local manifest
  manifest=$(curl -sf --max-time 15 "$manifest_url" 2>/dev/null)
  if [ -z "$manifest" ]; then
    echo -e "  ${YELLOW}[!]${NC} Could not reach update server. Falling back to git pull..."
    _upgrade_git_pull "$kb_dir"
    return $?
  fi

  local latest
  latest=$(echo "$manifest" | python3 -c "import sys,json; m=json.load(sys.stdin); print(m.get('channels',{}).get('$channel', m.get('latest','')))" 2>/dev/null)

  if [ -z "$latest" ]; then
    echo -e "  ${RED}[âś—]${NC} Could not determine latest version from manifest."
    return 1
  fi

  echo -e "  Current:  v${current_version}"
  echo -e "  Latest:   v${latest}"

  if [ "$current_version" = "$latest" ]; then
    echo ""
    echo -e "  ${GREEN}[âś“]${NC} Already running the latest version."
    _upgrade_images
    return 0
  fi

  # Step 2: Get download URL and checksum
  local download_url checksum
  download_url=$(echo "$manifest" | python3 -c "import sys,json; print(json.load(sys.stdin)['releases']['$latest']['download'])" 2>/dev/null)
  checksum=$(echo "$manifest" | python3 -c "import sys,json; print(json.load(sys.stdin)['releases']['$latest']['sha256'])" 2>/dev/null)

  if [ -z "$download_url" ]; then
    echo -e "  ${YELLOW}[!]${NC} No download URL for v${latest}. Falling back to git pull..."
    _upgrade_git_pull "$kb_dir"
    return $?
  fi

  # Step 3: Download
  echo ""
  echo -e "  ${BLUE}[â†’]${NC} Downloading v${latest}..."
  local tmp_dir
  tmp_dir=$(mktemp -d)
  local bundle_file="$tmp_dir/softwarefactory-v${latest}.tar.gz"

  if ! curl -fL --max-time 120 -o "$bundle_file" "$download_url" 2>/dev/null; then
    echo -e "  ${RED}[âś—]${NC} Download failed."
    rm -rf "$tmp_dir"
    return 1
  fi

  # Step 4: Verify checksum
  if [ -n "$checksum" ]; then
    echo -e "  ${BLUE}[â†’]${NC} Verifying checksum..."
    local actual_checksum
    actual_checksum=$(sha256sum "$bundle_file" | awk '{print $1}')
    if [ "$actual_checksum" != "$checksum" ]; then
      echo -e "  ${RED}[âś—]${NC} Checksum mismatch! Expected: ${checksum:0:16}... Got: ${actual_checksum:0:16}..."
      echo -e "  ${RED}    Download may be corrupted. Aborting.${NC}"
      rm -rf "$tmp_dir"
      return 1
    fi
    echo -e "  ${GREEN}[âś“]${NC} Checksum verified."
  fi

  # Step 5: Backup current version
  echo -e "  ${BLUE}[â†’]${NC} Backing up current version..."
  local backup_dir="$kb_dir/.backup-v${current_version}"
  if [ -d "$kb_dir/installer" ]; then
    cp -a "$kb_dir/installer" "$backup_dir" 2>/dev/null || true
  fi

  # Step 6: Apply update
  echo -e "  ${BLUE}[â†’]${NC} Applying update..."
  tar -xzf "$bundle_file" -C "$kb_dir" --strip-components=1 2>/dev/null
  rm -rf "$tmp_dir"

  # Step 7: Update version in config
  if [ -f "$KB_CONFIG" ]; then
    if grep -q "^KB_VERSION=" "$KB_CONFIG"; then
      sed -i "s/^KB_VERSION=.*/KB_VERSION=\"${latest}\"/" "$KB_CONFIG"
    else
      echo "KB_VERSION=\"${latest}\"" >> "$KB_CONFIG"
    fi
  fi

  # Step 8: Update CLI
  if [ -f "$kb_dir/installer/kb" ]; then
    sudo cp "$kb_dir/installer/kb" /usr/local/bin/kb 2>/dev/null
    sudo chmod +x /usr/local/bin/kb 2>/dev/null
  fi

  # Step 9: Upgrade running images
  _upgrade_images

  echo ""
  echo -e "  ${GREEN}[âś“]${NC} Upgraded to v${latest} successfully!"
  echo -e "  Backup at: $backup_dir"
  echo -e "  Run 'kb status' to verify."
}

_upgrade_git_pull() {
  local kb_dir="$1"
  if [ -d "$kb_dir/.git" ]; then
    echo -e "  ${BLUE}[â†’]${NC} Pulling latest from Git..."
    cd "$kb_dir" && git pull origin main 2>/dev/null
    echo -e "  ${GREEN}[âś“]${NC} Updated from Git."
    _upgrade_images
    return 0
  else
    echo -e "  ${RED}[âś—]${NC} No git repo found at $kb_dir. Clone fresh:"
    echo -e "      git clone https://github.com/AndresBardales/softwarefactory.git"
    return 1
  fi
}

_upgrade_images() {
  local docker_user="${KB_DOCKER_USER:-${KB_DOCKER_USERNAME:-}}"
  if [ -z "$docker_user" ]; then
    return 0
  fi
  echo ""
  echo -e "  ${BLUE}[â†’]${NC} Restarting platform services with latest images..."
  kubectl -n prod rollout restart deployment/kaanbal-api deployment/kaanbal-console 2>/dev/null || true
  echo -e "  ${GREEN}[âś“]${NC} Services restarting. Pods will pull latest images."
}

cmd_add_worker() {
  echo -e "${BOLD}${CYAN}Add Cloud Worker${NC}"
  echo ""

  if [ "${KB_MODE:-}" = "local" ]; then
    echo "  Worker nodes are only available in cloud or hybrid mode."
    echo "  Current mode: local"
    echo ""
    echo "  To switch to hybrid mode, run: kb config --set KB_MODE=hybrid"
    return 1
  fi

  echo "  This will add a new worker node to your cluster."
  echo "  Provider: AWS (region: ${KB_AWS_REGION:-us-east-1})"
  echo ""
  echo "  [!] Not yet implemented. Planned for v1.1."
  echo "  For now, modify worker_desired_count in terraform.tfvars and run terraform apply."
}

cmd_help() {
  cat <<HELP
${BOLD}Kaanbal Engine CLI v${KB_VERSION:-1.0.0}${NC}

${BOLD}Usage:${NC} kb <command> [options]

${BOLD}Commands:${NC}
  install           Install Kaanbal Engine (interactive wizard)
  status            Show cluster health, nodes, and services
  apps              List all deployed applications
  logs <app>        View logs for an app (--env, --follow)
  config            Show current configuration
  upgrade           Pull latest images and restart services
  add-worker        Add a cloud worker node (cloud/hybrid)
  uninstall         Remove Kaanbal Engine
  help              Show this help

${BOLD}Examples:${NC}
  kb status                   Check everything is running
  kb apps                     See your deployed apps
  kb logs my-api --follow     Stream logs from my-api
  kb upgrade                  Update to latest version

${BOLD}Environment:${NC}
  KB_HOME     Config directory (default: ~/.kaanbal)

HELP
}

# ==============================================================================
# MAIN
# ==============================================================================

command="${1:-help}"
shift 2>/dev/null || true

case "$command" in
  install)    exec bash "$(dirname "$0")/install.sh" ;;
  status)     cmd_status ;;
  apps)       cmd_apps ;;
  logs)       cmd_logs "$@" ;;
  config)     cmd_config ;;
  upgrade)    cmd_upgrade "$@" ;;
  add-worker) cmd_add_worker ;;
  version|--version|-v) echo "Kaanbal Engine v${KB_VERSION:-0.0.0}" ;;
  help|--help|-h) cmd_help ;;
  *)
    echo -e "${RED}Unknown command: $command${NC}"
    echo "Run 'kb help' for usage."
    exit 1
    ;;
esac
