# =============================================================================
# Software Factory — Quick Start Configuration
# =============================================================================
# Copy this file, fill in your values, and run:
#   bash install.sh --config config.env
#
# This skips the interactive wizard entirely.
# Leave fields blank to use defaults. Only SF_MODE is required.
# =============================================================================

# ── Installation Mode (REQUIRED) ─────────────────────────────────────────────
# Options: local | cloud | hybrid
#   local  — Everything runs on this machine. Apps on localhost.
#   cloud  — Provision AWS infrastructure. Apps on public domain.
#   hybrid — Local master + cloud gateway for public access.
SF_MODE="local"

# ── Git Provider ─────────────────────────────────────────────────────────────
# Options: github | bitbucket | gitlab
SF_GIT_PROVIDER="github"
SF_GIT_USERNAME=""
SF_GIT_EMAIL=""
SF_GIT_TOKEN=""

# Bitbucket only:
SF_BITBUCKET_WORKSPACE=""

# GitHub only:
SF_GITHUB_ORG=""

# ── Docker Hub ───────────────────────────────────────────────────────────────
SF_DOCKER_USERNAME=""
SF_DOCKER_TOKEN=""

# ── Domain & Networking ─────────────────────────────────────────────────────
# Local mode: "localhost" (or "<lan-ip>.nip.io" for LAN access)
# Cloud/Hybrid: your domain (e.g., "yourdomain.com")
SF_DOMAIN="localhost"
SF_ELASTIC_IP=""
SF_ENABLE_TLS=false

# ── Tailscale (optional for local, required for hybrid) ─────────────────────
# Get OAuth credentials at: https://login.tailscale.com/admin/settings/oauth
# Scopes needed: Devices:Write, Auth Keys:Write
SF_TAILSCALE_ENABLED=false
SF_TAILSCALE_CLIENT_ID=""
SF_TAILSCALE_CLIENT_SECRET=""
SF_TAILSCALE_DNS_SUFFIX=""

# ── AWS (cloud/hybrid only) ─────────────────────────────────────────────────
SF_AWS_REGION="us-east-1"
SF_AWS_ACCESS_KEY=""
SF_AWS_SECRET_KEY=""

# ── Admin Credentials ────────────────────────────────────────────────────────
# Password is auto-generated if left blank.
SF_ADMIN_USER="admin"
SF_ADMIN_PASSWORD=""

# ── Core Control Plane Secrets (REQUIRED for complete bootstrap) ───────────
# ArgoCD password used by nexus-api to connect and refresh app status.
SF_ARGOCD_PASSWORD=""
# Vault token seeded into system_config.vault_token (e.g. vault_init_token).
SF_VAULT_TOKEN=""
